# InsForge Backend (obligatorias en Vercel para build y tienda)
NEXT_PUBLIC_INSFORGE_URL=https://xxggjg42.us-east.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=tu-anon-key-aqui

# URL pública (SEO, redirects auth, Culqi). Local: http://localhost:3000 | Prod: https://excusasjeans.com
# En InsForge → Auth: allowed redirect URLs (/perfil local y prod) y
# requireEmailVerification=false (login sin verificar; la app envía el correo y avisa en /perfil)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Panel admin (subdominio). Producción: admin.excusasjeans.com
NEXT_PUBLIC_ADMIN_HOST=admin.excusasjeans.com
NEXT_PUBLIC_ADMIN_URL=https://admin.excusasjeans.com

# Contacto legal (footer, libro de reclamaciones, Culqi)
NEXT_PUBLIC_CONTACT_EMAIL=ventasexcusas@gmail.com
NEXT_PUBLIC_BUSINESS_ADDRESS=Gamarra 465, Galería de los Jeans, Tda. 127, Primer piso, La Victoria, Lima

# Google Search Console — código de verificación (opcional)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=tu-codigo-aqui

# API key de administrador InsForge (obligatoria en local y Vercel)
INSFORGE_ADMIN_API_KEY=tu-admin-api-key-aqui

# Culqi — pagos en línea (https://culqi.com)
NEXT_PUBLIC_CULQI_PUBLIC_KEY=pk_test_xxxxxxxx
CULQI_SECRET_KEY=sk_test_xxxxxxxx

# Credenciales de prueba para revisión Culqi (crear usuario en /cuenta)
# CULQI_DEMO_EMAIL=demo@excusasjeans.com
